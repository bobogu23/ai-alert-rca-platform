flowchart TB
    subgraph SRC["告警接入层"]
        A1["伽利略告警 Webhook<br/>Prometheus Alertmanager"]
        A2["Alert Ingest Gateway<br/>Spring Boot"]
    end

    subgraph SUP["告警治理层"]
        B1["指纹去重<br/>Dedup Engine"]
        B2["抑制规则引擎<br/>Suppression Engine"]
        B3["级联告警合并<br/>Correlation Engine"]
        B4["告警状态机<br/>Alert State Store<br/>Redis + MySQL"]
    end

    subgraph ORCH["编排层（Java）"]
        C1["Orchestrator Service<br/>Spring Boot 编排核心"]
        C2["配置化路由引擎<br/>Routing Engine<br/>(七彩石规则 + LLM 兜底)"]
    end

    subgraph AGENT["AI Agent 层（Spring AI 2.0）"]
        D1["LogAnalysisAgent<br/>日志检索/去重/堆栈裁剪"]
        D2["TraceMetricAgent<br/>伽利略 Trace/Metric 瓶颈定位"]
        D3["CodeContextAgent<br/>代码仓库定位与静态分析"]
        D5["RootCauseReasoningAgent<br/>多路证据融合与根因推理"]
        D6["ReportGeneratorAgent<br/>结构化报告生成"]
        D7["CriticAgent<br/>自校验/证据核对/反幻觉"]
    end

    subgraph MCPL["工具接入层（MCP Server）"]
        E1["CLS MCP Server<br/>日志查询/聚合"]
        E2["Galileo MCP Server<br/>Trace/Metric/Alert 查询"]
        E3["CodeRepo MCP Server<br/>代码检索/Blame/最近发布"]
    end

    subgraph LLMGW["大模型接入层"]
        L1["LiteLLM 网关<br/>统一 OpenAI 兼容协议<br/>多模型路由 / Failover"]
    end

    subgraph DATAL["数据与存储层"]
        F2[("MySQL<br/>告警台账 / 案卷记录")]
        F3[("Redis<br/>去重指纹 / 热点缓存")]
        F4[("对象存储<br/>原始报告 / 证据快照")]
    end

    subgraph OUTL["输出层"]
        G1["归因报告<br/>Markdown / 结构化JSON"]
        G2["NotificationGateway<br/>可扩展通知网关"]
        G3[["企业微信 Channel<br/>v1 已启用"]]
        G4[["预留 Channel<br/>工单 / 邮件 / 短信 ..."]]
    end

    A1 --> A2 --> B1 --> B2 --> B3 --> B4
    B4 -->|需要分析的告警| C1
    C1 -->|告警分类路由| C2
    C2 --> C1
    C1 --> D1 & D2 & D3
    D1 --> E1
    D2 --> E2
    D3 --> E3
    D1 & D2 & D3 --> D5
    D5 --> D7
    D7 -->|通过校验| D6
    D7 -->|证据不足/存疑| D5
    AGENT -. 统一走 LiteLLM 网关 .-> LLMGW
    D6 --> G1 --> G2
    G2 --> G3
    G2 -. 预留扩展 .-> G4
    B4 --> F3
    B4 --> F2
    D6 --> F4
